# See https://docs.github.com/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# Compiled output
/dist
/tmp
/out-tsc
/bazel-out

# Node
/node_modules
npm-debug.log
yarn-error.log

# IDEs and editors
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/*

# Miscellaneous
/.angular/cache
.sass-cache/
/connect.lock
/coverage
/libpeerconnection.log
testem.log
/typings

# System files
.DS_Store
Thumbs.db

# BEGIN grimoire
# Runtime state produced by Grimoire — commit .grimoire/seal.json so every
# teammate / CI agrees on what's already documented, but keep progress
# checkpoints and agent logs out of history.
.grimoire/progress.json
.grimoire/logs/
.grimoire/cache/
.grimoire-progress.json

# Design skill installs (regenerated on every `grimoire cast`).
# These specific subtrees are owned by the upstream `npx skills add`
# CLI (vercel-labs/skills) — never hand-edit, never commit. The parent
# `<host>/skills/` directories stay tracked so any skills you author
# yourself remain in git history.
.agents/skills/ui-ux-pro-max/
.agents/skills/impeccable/
.claude/skills/ui-ux-pro-max/
.claude/skills/impeccable/
.codex/skills/ui-ux-pro-max/
.codex/skills/impeccable/
.opencode/skills/ui-ux-pro-max/
.opencode/skills/impeccable/
.copilot/skills/ui-ux-pro-max/
.copilot/skills/impeccable/
.github/copilot/skills/ui-ux-pro-max/
.github/copilot/skills/impeccable/
skills-lock.json
# END grimoire
